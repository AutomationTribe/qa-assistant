# App
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=mysql://regi:YOUR_MYSQL_PASSWORD@127.0.0.1:3306/regi_prod

# Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@127.0.0.1:6379

# JWT — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_THIS
JWT_REFRESH_SECRET=GENERATE_THIS_TOO

# Encryption — must be exactly 32 characters
ENCRYPTION_KEY=exactly_32_characters_goes_here_

# OpenAI
OPENAI_API_KEY=sk-your-key-here
DEFAULT_LLM_MODEL=gpt-4o

# Zephyr
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
